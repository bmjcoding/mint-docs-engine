{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Acme Docs",
  "colors": {
    "primary": "#0ea5e9"
  },
  "logo": {
    "light": "/logo-light.svg",
    "dark": "/logo-dark.svg"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "quickstart"]
          },
          {
            "group": "Guides",
            "pages": ["authentication", "webhooks"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Endpoints",
            "pages": ["api/users", "api/projects"]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      { "label": "GitHub", "url": "https://github.com" }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com"
    }
  },
  "appearance": {
    "default": "system"
  },
  "search": {
    "prompt": "Search documentation..."
  }
}
