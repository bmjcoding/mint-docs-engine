{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Acme Docs",
  "redirects": [
    { "source": "/beta/:slug*", "destination": "/v2/:slug*" }
  ],
  "colors": {
    "primary": "#0ea5e9"
  },
  "logo": {
    "light": "/logo-light.svg",
    "dark": "/logo-dark.svg",
    "href": "https://mintlify.com"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Getting started",
        "groups": [
          {
            "group": "Getting started",
            "pages": ["introduction", "quickstart", "changelog"]
          },
          {
            "group": "Guides",
            "pages": [
              "authentication",
              "webhooks",
              {
                "group": "Advanced Guides",
                "icon": "book-open",
                "pages": ["api/users"]
              }
            ]
          }
        ]
      },
      {
        "tab": "Build with Claude Code",
        "groups": [
          {
            "group": "Endpoints",
            "pages": ["api/users", "api/projects"]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      { "label": "GitHub", "url": "https://github.com" }
    ],
    "primary": {
      "type": "button",
      "label": "Sign Up",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com"
    }
  },
  "appearance": {
    "default": "system"
  },
  "search": {
    "prompt": "Search documentation..."
  }
}
